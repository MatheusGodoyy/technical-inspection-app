{
  "expo": {
    "name": "Inspeção Técnica Digital",
    "slug": "inspecao-tecnica-digital",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sylvamo.inspecao",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Precisamos salvar fotos na sua galeria"
      }
    },
    "android": {
      "package": "com.sylvamo.inspecao",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "4d5e5109-384f-4ca9-9902-d02726f2292e"
      }
    }
  }
}